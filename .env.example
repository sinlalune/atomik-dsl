# Generability eval credentials (CP-DSL-003 S04). Copy to `.env` and fill in.
# `.env` is gitignored — never commit real keys. Loaded automatically by
# `npm run eval:live` via Node's built-in --env-file-if-exists (no dotenv dep).
# KEY=value form only — do NOT prefix with `export`.

# Anthropic: subject model (Haiku 4.5) + judge (Sonnet 5). https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini: subject model (Gemini 3.1 Flash-Lite). https://aistudio.google.com/apikey
GEMINI_API_KEY=...
