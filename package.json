{
  "name": "atomik-dsl",
  "private": true,
  "version": "0.3.0",
  "description": "atomik — the learning-visualization DSL for Atomik (lang-core + render-core kernels, M12 target).",
  "type": "commonjs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node packages/dsl-core/test/test_atomik_core.js",
    "build:prototype": "node apps/prototype-cycle/build.mjs",
    "eval:validate": "node apps/eval-generability/validate_tasks.mjs",
    "eval:test": "node apps/eval-generability/test_harness.mjs",
    "eval:dry-run": "node apps/eval-generability/run.mjs --dry-run",
    "eval:build": "node apps/eval-generability/run.mjs build",
    "eval:live": "node --env-file-if-exists=.env apps/eval-generability/run.mjs live",
    "eval:report": "node apps/eval-generability/report.mjs",
    "demo": "node --env-file-if-exists=.env apps/generate-demo/server.mjs"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@google/genai": "^2.10.0"
  }
}
