# Git hygiene per main-repo bedrock 27 (caches/derived state never canonical)
node_modules/
.atomik/
.DS_Store

# Secrets: real keys live in .env (never committed); .env.example is the template.
.env
.env.local
.env.*.local

# Eval: dry-run output is synthetic + regenerable; batch bodies are regenerable.
# Live results (results/live-*/) are the real data and ARE committed (CP-DSL-003 S04).
apps/eval-generability/results/dry-run/
apps/eval-generability/results/batch-*/

# Demo: saved generations are local user data (the demo reads them back).
apps/generate-demo/saved/
